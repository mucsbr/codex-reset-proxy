UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_API_KEY=
UPSTREAM_API_KEY_HEADER=Authorization
# Keep the trailing space after Bearer. Set this to empty for raw-key headers.
UPSTREAM_API_KEY_PREFIX=Bearer 
PROXY_PORT=8788

# Build-time network settings. Defaults favor mainland China PyPI access.
PYTHON_IMAGE=python:3.12-slim
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_DEFAULT_TIMEOUT=120
