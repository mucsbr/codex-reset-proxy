UPSTREAM_BASE_URL=https://api.openai.com
UPSTREAM_API_KEY=
UPSTREAM_API_KEY_HEADER=Authorization
# Keep the trailing space after Bearer. Set this to empty for raw-key headers.
UPSTREAM_API_KEY_PREFIX=Bearer 
PROXY_PORT=8788
LISTEN_PROTOCOL=http_reverse
OUTBOUND_PROXY=
TRANSPORT_MODE=http
INTERCEPT_HOST=
INTERCEPT_PATHS=/backend-api/codex/responses
MITM_CERT_DIR_HOST=./certs
WEBSOCKET_FIRST_MESSAGE_TIMEOUT_SECONDS=30
WEBSOCKET_IDLE_TIMEOUT_SECONDS=600
WEBSOCKET_PROCESSED_TIMEOUT_SECONDS=10
WEBSOCKET_SEND_RESPONSE_PROCESSED=true
WEBSOCKET_POOL_ENABLED=false
WEBSOCKET_POOL_MAX_IDLE=8
WEBSOCKET_POOL_IDLE_TIMEOUT_SECONDS=300
WEBSOCKET_POOL_KEY_HEADERS=authorization,cookie,x-api-key,api-key,openai-organization,openai-project,chatgpt-account-id

# Build-time network settings. Defaults favor mainland China PyPI access.
PYTHON_IMAGE=python:3.12-slim
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
PIP_DEFAULT_TIMEOUT=120
